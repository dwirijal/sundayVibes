{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "command": "node .claude/scripts/guardrails.js"
      }
    ],
    "Stop": [
      {
        "command": "npm run lint && npm run build"
      }
    ]
  }
}
