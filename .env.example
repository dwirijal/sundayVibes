# Sunday Vibes — Environment Variables
# Copy to .env.local and fill in. All secrets via Vercel env vars in prod.

# Database (Neon PostgreSQL)
DATABASE_URI=postgresql://user:password@ep-hostname.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Payload CMS
PAYLOAD_SECRET=generate-a-long-random-string

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel (deployment)
# Set in Vercel project settings, not committed.

# Payments (manual QRIS verification only)
# MIDTRANS_SERVER_KEY=         # unused — kept for reference; remove if not needed
# MIDTRANS_CLIENT_KEY=         # unused — kept for reference; remove if not needed

# Seed admin (required by `npm run seed:admin` — min 12 chars, never commit real value)
# SEED_ADMIN_EMAIL=admin@sundayvibes.com
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_NAME=Admin

# WhatsApp webhook (required — forged POSTs rejected without it)
# WHATSAPP_WEBHOOK_SECRET=

# Neon Auth (optional — client dashboard uses Payload; keep for future OAuth bridge)
# NEON_AUTH_BASE_URL=
# NEON_AUTH_COOKIE_SECRET=

# Resend (email notifications)
RESEND_API_KEY=

# GitHub (for Vercel deploy workflow)
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# Jules (Google) REST API — generate key at https://jules.google/settings
# Source = your connected GitHub repo. Install Jules GitHub app first.
JULES_API_KEY=
JULES_SOURCE=sources/github/dwirijal/sundayVibes
